# === Application ===
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
# APP_CORS_ORIGINS — auto-built from SERVER_NAME if not set
# APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://dev.vkus.online"]

# === Database ===
DATABASE_URL=postgresql+asyncpg://vkus:vkus_secret@localhost:5432/vkus_online
DATABASE_ECHO=false

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# === Guest Sessions ===
GUEST_SESSION_TTL_DAYS=180

# === 5Post ===
FIVEPOST_BASE_URL=https://api-omni.x5.ru
FIVEPOST_API_KEY=
FIVEPOST_WAREHOUSE_ID=

# === Magnit ===
MAGNIT_BASE_URL=https://b2b-api.magnit.ru
MAGNIT_CLIENT_ID=
MAGNIT_CLIENT_SECRET=
MAGNIT_WAREHOUSE_UUID=

# === YooKassa ===
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# YOOKASSA_RETURN_URL — auto-built from SERVER_NAME if not set
# YOOKASSA_RETURN_URL=https://dev.vkus.online/#/orders
YOOKASSA_WEBHOOK_SECRET=

# === DaData ===
DADATA_API_KEY=
DADATA_SECRET_KEY=

# === Storage ===
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/storage

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Delivery terms (shown in emails and checkout page) ===
MAGNIT_DELIVERY_TERMS=Вы получите СМС с номером заказа и кодом получения.\nПри получении подтверждения личности не требуется.\nПри получении нужно назвать код и номер заказа из СМС.\nЗаказ хранится в ПВЗ 5 дней. Хранение можно продлить на 5 дней через поддержку.
FIVEPOST_DELIVERY_TERMS=Вы получите СМС с кодом для получения.\nПри получении подтверждение личности не нужно.\nЕсли у вас нет возможности забрать заказ, его могут получить те, кому вы сообщите код.\nСрок хранения 7 дней, далее можно будет продлить в личном кабинете на два дня бесплатно.

