# === Application ===
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# === Database ===
DATABASE_URL=postgresql+asyncpg://vkus:vkus_secret@localhost:5432/vkus_online
DATABASE_ECHO=false

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# === Guest Sessions ===
GUEST_SESSION_TTL_DAYS=180

# === 5Post ===
FIVEPOST_BASE_URL=https://api-omni.x5.ru
FIVEPOST_API_KEY=
FIVEPOST_WAREHOUSE_ID=

# === Magnit ===
MAGNIT_BASE_URL=https://b2b-api.magnit.ru
MAGNIT_CLIENT_ID=
MAGNIT_CLIENT_SECRET=
MAGNIT_WAREHOUSE_UUID=

# === YooKassa ===
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://vkus.online/payment/return
YOOKASSA_WEBHOOK_SECRET=

# === DaData ===
DADATA_API_KEY=
DADATA_SECRET_KEY=

# === Storage ===
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/storage

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json
